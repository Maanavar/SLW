# Siva Lathe Works - Environment Configuration
# Backend environment lives in backend/.env.example

# API Configuration (if backend is added)
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000
VITE_ENABLE_BACKEND_SYNC=true

# Feature Flags
VITE_ENABLE_REPORTS=true
VITE_ENABLE_PAYMENT_SYNC=false
VITE_ENABLE_OFFLINE_LOGIN=false

# Application Settings
VITE_APP_TIMEZONE=Asia/Kolkata
VITE_CURRENCY_SYMBOL=INR

# Error Tracking (leave empty to disable)
VITE_SENTRY_DSN=

# Debug & Logging
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
