# Siva Lathe Works - Environment Configuration
# Backend environment lives in backend/.env.example

# API Configuration (if backend is added)
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000
VITE_ENABLE_BACKEND_SYNC=true
VITE_ADMIN_API_KEY=slw-local-admin-key

# Feature Flags
VITE_ENABLE_REPORTS=true
VITE_ENABLE_PAYMENT_SYNC=false

# Application Settings
VITE_APP_TIMEZONE=Asia/Kolkata
VITE_CURRENCY_SYMBOL=₹

# Debug & Logging
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
