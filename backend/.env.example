NODE_ENV=development
PORT=3001

# Local PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://slw_admin:slw_dev_password@localhost:5432/slw_local?schema=public

# Allow frontend during local dev
CORS_ORIGIN=http://localhost:5173

# Optional guard for admin purge endpoints
ADMIN_API_KEY=slw-local-admin-key
AUTH_SESSION_SECRET=change-this-in-production
AUTH_SESSION_HOURS=12
AUTH_DEFAULT_ADMIN_EMAIL=local-admin@slw.local
AUTH_ALLOW_LEGACY_API_KEY_LOGIN=true

# Backup scheduler/storage
# Directory can be absolute or relative to backend working directory.
BACKUP_DIRECTORY=../backups
# Set 0 to disable automatic scheduled backups.
BACKUP_SCHEDULE_HOURS=24
BACKUP_RETENTION_DAYS=30

# Error Tracking (leave empty to disable)
SENTRY_DSN=
