generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(120)
  email        String        @unique @db.VarChar(160)
  role         String        @default("admin") @db.VarChar(20)
  passwordHash String        @db.VarChar(255)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]

  @@map("users")
}

model Customer {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(120)
  shortCode      String    @db.VarChar(20)
  type           String    @db.VarChar(20)
  hasCommission  Boolean   @default(false)
  requiresDc     Boolean   @default(false)
  hasBillNo      Boolean   @default(false)
  advanceBalance  Decimal   @default(0) @db.Decimal(14, 2)
  openingBalance  Decimal   @default(0) @db.Decimal(14, 2)
  invoiceGroup    String?   @db.VarChar(10)
  notes           String    @default("")
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  jobs            Job[]
  payments        Payment[]
  commissionWorkers CommissionWorker[]
  followUp       CustomerFollowUp?

  @@index([name])
  @@index([shortCode])
  @@map("customers")
}

model WorkType {
  id          Int      @id @default(autoincrement())
  category    String   @db.VarChar(60)
  name        String   @db.VarChar(120)
  shortCode   String   @db.VarChar(20)
  defaultUnit String   @db.VarChar(30)
  defaultRate Decimal  @db.Decimal(14, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([category])
  @@map("work_types")
}

model Job {
  id                        Int       @id @default(autoincrement())
  customerId                Int
  workTypeName              String    @db.VarChar(120)
  workName                  String?   @db.VarChar(60)
  quantity                  Float
  amount                    Decimal   @db.Decimal(14, 2)
  commissionAmount          Decimal   @default(0) @db.Decimal(14, 2)
  commissionWorkerId        Int?
  commissionWorkerName      String?   @db.VarChar(120)
  netAmount                 Decimal?  @db.Decimal(14, 2)
  date                      String    @db.VarChar(10)
  paymentStatus             String?   @db.VarChar(20)
  paymentMode               String?   @db.VarChar(20)
  paidAmount                Decimal?  @db.Decimal(14, 2)
  workMode                  String?   @db.VarChar(20)
  isSpotWork                Boolean   @default(false)
  jobCardId                 String?   @db.VarChar(30)
  jobCardLine               Int?
  billNo                    String?   @db.VarChar(40)
  dcNo                      String?   @db.VarChar(40)
  vehicleNo                 String?   @db.VarChar(40)
  dcDate                    String?   @db.VarChar(10)
  dcApproval       Boolean?
  rmpHandler       String?   @db.VarChar(20)
  jobFlowType               String?   @db.VarChar(20)
  externalDc                Boolean?  @default(false)
  agentName                 String?   @db.VarChar(120)
  agentCommissionAmount     Decimal?  @default(0) @db.Decimal(14, 2)
  agentTdsAmount            Decimal?  @default(0) @db.Decimal(14, 2)
  agentSettlementPaidAmount Decimal?  @default(0) @db.Decimal(14, 2)
  notes                     String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([date])
  @@index([customerId, date])
  @@index([commissionWorkerId])
  @@index([jobCardId])
  @@index([billNo])
  @@map("jobs")
}

model Payment {
  id                 Int      @id @default(autoincrement())
  customerId         Int
  amount             Decimal  @db.Decimal(14, 2)
  date               String   @db.VarChar(10)
  paymentMode        String   @db.VarChar(20)
  breakdown          Json?
  referenceNumber    String?  @db.VarChar(60)
  paymentForMonth    String?  @db.VarChar(20)
  paymentForDate     String?  @db.VarChar(10)
  paymentForFromDate String?  @db.VarChar(10)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([date])
  @@index([customerId, date])
  @@map("payments")
}

model CommissionWorker {
  id         Int      @id @default(autoincrement())
  customerId Int
  name       String   @db.VarChar(120)
  shareType  String   @db.VarChar(20)
  shareValue Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([customerId])
  @@map("commission_workers")
}

model CommissionPayment {
  id         Int      @id @default(autoincrement())
  workerId   Int
  workerName String   @db.VarChar(120)
  customerId Int
  jobIds     Json
  amount     Decimal  @db.Decimal(14, 2)
  date       String   @db.VarChar(10)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([workerId])
  @@index([customerId])
  @@index([date])
  @@map("commission_payments")
}

model Expense {
  id           Int      @id @default(autoincrement())
  category     String   @db.VarChar(20)
  description  String   @db.VarChar(255)
  amount       Decimal  @db.Decimal(14, 2)
  date         String   @db.VarChar(10)
  isRecurring  Boolean  @default(false)
  recurringDay Int?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([category, date])
  @@index([isRecurring])
  @@map("expenses")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  actorName   String?  @db.VarChar(120)
  entityType  String   @db.VarChar(50)
  entityId    String?  @db.VarChar(50)
  action      String   @db.VarChar(50)
  message     String?  @db.VarChar(500)
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([createdAt])
  @@index([entityType, createdAt])
  @@map("activity_logs")
}

model CustomerFollowUp {
  customerId        Int      @id
  nextFollowUpDate  String   @db.VarChar(10)
  notes             String?  @db.VarChar(1000)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([nextFollowUpDate])
  @@map("customer_followups")
}

model MonthLock {
  monthKey       String   @id @db.VarChar(7)
  notes          String?  @db.VarChar(500)
  lockedByUserId Int?
  lockedByName   String?  @db.VarChar(120)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("month_locks")
}

model SystemSetting {
  key       String   @id @db.VarChar(80)
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
