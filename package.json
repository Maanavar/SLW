{
  "name": "siva-lathe-works",
  "version": "1.0.0",
  "description": "Business management system for Siva Lathe Works",
  "main": "dist/app.js",
  "scripts": {
    "dev": "npm run copy-assets && esbuild src/js/index.js --bundle --watch --outfile=dist/app.js --sourcemap",
    "build": "npm run test && npm run copy-assets && esbuild src/js/index.js --bundle --minify --outfile=dist/app.js",
    "build:full": "npm run lint:check && npm run format:check && npm run test && npm run copy-assets && esbuild src/js/index.js --bundle --minify --outfile=dist/app.js",
    "build:fast": "npm run copy-assets && esbuild src/js/index.js --bundle --minify --outfile=dist/app.js",
    "copy-assets": "node scripts/copy-assets.js",
    "preview": "npx http-server dist -p 8080",
    "lint": "eslint src/**/*.js --fix",
    "lint:check": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.{js,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint:check && npm run format:check && npm run type-check && npm run test"
  },
  "keywords": [
    "business",
    "manufacturing",
    "lathe",
    "management"
  ],
  "author": "Siva Lathe Works Team",
  "license": "UNLICENSED",
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "babel-jest": "^30.3.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
