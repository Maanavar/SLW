{
  "name": "siva-lathe-works",
  "version": "1.0.0",
  "description": "Business management system for Siva Lathe Works",
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite",
    "dev:react": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "build": "vite build",
    "build:fast": "vite build",
    "build:react": "vite build",
    "build:backend": "npm --prefix backend run build",
    "format:check": "prettier --check .",
    "lint:check": "eslint \"src/**/*.{ts,tsx}\" \"backend/src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "npx http-server dist -p 8080",
    "preview:react": "npx http-server dist -p 8080",
    "type-check": "tsc --noEmit",
    "type-check:backend": "npm --prefix backend run type-check",
    "validate": "npm run type-check && npm run type-check:backend && npm run build && npm run build:backend",
    "db:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d postgres adminer",
    "db:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts\\backup-db.ps1",
    "db:restore": "powershell -ExecutionPolicy Bypass -File scripts\\restore-db.ps1",
    "db:backup:schedule": "powershell -ExecutionPolicy Bypass -File scripts\\setup-scheduled-backup.ps1"
  },
  "keywords": [
    "business",
    "manufacturing",
    "lathe",
    "management"
  ],
  "author": "Siva Lathe Works Team",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.3",
    "esbuild": "^0.25.12",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^26.1.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.2",
    "vitest": "^4.0.3"
  },
  "dependencies": {
    "@sentry/react": "^10.51.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.24",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.1",
    "zustand": "^4.4.0"
  }
}
