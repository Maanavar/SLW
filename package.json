{
  "name": "siva-lathe-works",
  "version": "1.0.0",
  "description": "Business management system for Siva Lathe Works",
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite",
    "dev:react": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "build": "vite build",
    "build:react": "vite build",
    "build:backend": "npm --prefix backend run build",
    "preview": "npx http-server dist -p 8080",
    "preview:react": "npx http-server dist -p 8080",
    "type-check": "tsc --noEmit",
    "type-check:backend": "npm --prefix backend run type-check",
    "validate": "npm run type-check && npm run build",
    "db:up": "docker compose up -d postgres adminer",
    "db:down": "docker compose down"
  },
  "keywords": [
    "business",
    "manufacturing",
    "lathe",
    "management"
  ],
  "author": "Siva Lathe Works Team",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.0"
  }
}
